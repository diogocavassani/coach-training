              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "dashboard",
                "atleta",
                "{{atletaId}}"
              ]
            },
            "description": "Retorna dashboard consolidado do atleta."
          },
          "response": []
        }
      ]
    },
