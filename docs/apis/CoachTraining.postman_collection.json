{
  "info": {
    "_postman_id": "615f3595-cf4c-457f-9124-f763407f15a9",
    "name": "CoachTraining API",
    "description": "Collection baseada na documentacao de API para Professor e Aluno (Atleta).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Professor e Auth",
      "item": [
        {
          "name": "POST /professores",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Professor Teste\",\n  \"email\": \"professor@teste.com\",\n  \"senha\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/professores",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "professores"
              ]
            },
            "description": "Cadastra um novo professor."
          },
          "response": []
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (e) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}",
                  "",
                  "if (data.expiraEmUtc) {",
                  "  pm.collectionVariables.set('tokenExpiraEmUtc', data.expiraEmUtc);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"professor@teste.com\",\n  \"senha\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Realiza login e salva o JWT em {{token}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Aluno (Atleta)",
      "item": [
        {
          "name": "POST /api/atleta",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let data = {};",
                  "try {",
                  "  data = pm.response.json();",
                  "} catch (e) {",
                  "  data = {};",
                  "}",
                  "",
                  "if (data.id) {",
                  "  pm.collectionVariables.set('atletaId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Atleta A\",\n  \"observacoesClinicas\": \"Sem restricoes\",\n  \"nivelEsportivo\": \"Intermediario\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/atleta",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "atleta"
              ]
            },
            "description": "Cria um atleta associado ao professor do token."
          },
          "response": []
        },
        {
          "name": "GET /api/atleta/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/atleta/{{atletaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "atleta",
                "{{atletaId}}"
              ]
            },
            "description": "Busca um atleta pelo ID (apenas do professor autenticado)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
